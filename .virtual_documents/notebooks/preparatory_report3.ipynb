# load and combine responses of different batches
subbatch_size = 1
rundate = "20260216"
model_names = ['gpt-4.1', 'gpt-4o', 'gpt-4o-mini']

all_responses_dict = {}
sum_usage_cost_dict = {}

for model_name in model_names:
    responses_dfs = []
    usage_cost_dfs = []
    
    for i_split in range(1, 6):
        # responses
        file_path = f"{project_root}/results/classification/classification_batchsize{subbatch_size}_{rundate}_{model_name}_test_{i_split}.csv"
        df = pd.read_csv(file_path)
        responses_dfs.append(df)
        # infobatch
        file_path = f"{project_root}/results/classification/infobatch_batchsize{subbatch_size}_{rundate}_{model_name}_test_{i_split}.csv"
        df = pd.read_csv(file_path)
        usage_cost_dfs.append(df)
    
    # concatenate
    all_responses_df = pd.concat(responses_dfs, ignore_index=True)
    usage_cost_df = pd.concat(usage_cost_dfs, ignore_index=True)
    
    # remove total row
    usage_cost_df = usage_cost_df[usage_cost_df['batch_name'] != 'total_batch']
    
    # sum costs
    sum_usage_cost_df = usage_cost_df.drop(columns='batch_name').sum()
    
    # store using model name as key
    all_responses_dict[model_name] = all_responses_df
    sum_usage_cost_dict[model_name] = sum_usage_cost_df

all_responses_df = pd.concat([df.assign(model_name=model_name) for model_name, df in all_responses_dict.items()],
                             ignore_index=True)
sum_usage_cost_df = pd.concat([s.to_frame().T.assign(model_name=model_name) for model_name, s in sum_usage_cost_dict.items()],
                              ignore_index=True)






metrics_by_model = {}
table_i = 8

for model_name, df_model in all_responses_df.groupby("model_name"):
    
    contingency_table= pd.crosstab(
        df_model['tobacco_product_true'],
        df_model['tobacco_product'],
        margins=True
    )
    
    contingency_table.index = ['Actual_No', 'Actual_Yes', 'Total']
    contingency_table.columns = ['Predicted_No', 'Predicted_Yes', 'Total']
    
    TP = contingency_table.loc['Actual_Yes', 'Predicted_Yes']
    FN = contingency_table.loc['Actual_Yes', 'Predicted_No']
    TN = contingency_table.loc['Actual_No', 'Predicted_No']
    FP = contingency_table.loc['Actual_No', 'Predicted_Yes']
    
    sensitivity = TP / (TP + FN)
    specificity = TN / (TN + FP)
    accuracy = (TP + TN) / (TP + TN + FP + FN)
    
    metrics_by_model[model_name] = {
        "sensitivity": sensitivity,
        "specificity": specificity,
        "accuracy": accuracy
    }

    display(contingency_table)
    display(Markdown(f"""**Tableau {table_i}** : Model {model_name}.  Sensibilité (True Positive Rate): {sensitivity:.2f}, spécificité (True Negative Rate): {specificity:.2f}, 
    précision (accuracy): {accuracy:.2f}."""))
    table_i+=1


