# Rounding logic
def round_columns(df):
    df = df.copy()
    for col in df.columns:
        if col.endswith('tokens'):
            df[col] = df[col].round(0).astype(int)   # integers
        elif col.endswith('cost'):
            df[col] = df[col].round(2)               # 2 decimals
    return df

sum_usage_cost_df = round_columns(sum_usage_cost_df)

